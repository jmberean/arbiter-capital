# Agent Cognition
OPENAI_API_KEY=sk-...

# Safe Owner Keys (each process signs with its own key)
QUANT_PRIVATE_KEY=0x...
PATRIARCH_PRIVATE_KEY=0x...
EXECUTOR_PRIVATE_KEY=0x...
KEEPERHUB_ATTESTOR_KEY=0x...
ATTACKER_PRIVATE_KEY=0x...   # byzantine_watchdog only — must NOT be a Safe owner

# Safe Smart Account
SAFE_ADDRESS=0x...
ETH_RPC_URL=https://rpc.ankr.com/eth_sepolia

# 0G Layer 1 Memory (Audit Trail)
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_PRIVATE_KEY=0x...
ZERO_G_CHAIN_ID=16602

# Uniswap v4
UNIVERSAL_ROUTER_ADDRESS=0x3fC91A3afd70395Cd496C647d5a6CC9D4B2b7FAD
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3
V4_POOL_MANAGER=0x000000000004444c5dc75cb358380d2e3de08a90
# Reference hooks on Sepolia (pin Day-5 morning from Uniswap deploy registry)
V4_HOOK_VOL_ORACLE=0x...
V4_HOOK_DYNAMIC_FEE=0x...
# Token addresses (Sepolia) — defaults baked into router.py, override here if needed
WETH_SEPOLIA=0xfFf9976782d46CC05630D1f6eBab18b2324d6B14
USDC_SEPOLIA=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
STETH_SEPOLIA=0x3e3FE7dBc6B4C189E7128855dD526361c49b40Af
WBTC_SEPOLIA=0x29f2D40B0605204364af54EC677bD022dA425d03
ARBITER_THROTTLE_HOOK=0x...
ARBITER_RECEIPT_NFT=0x...

# KeeperHub MCP
KEEPERHUB_SERVER_PATH=./keeperhub-server.js

# Gensyn AXL Networking — 5 separate nodes, one per daemon (see scripts/setup_axl.sh)
# Build: git clone https://github.com/gensyn-ai/axl && make build && cp node /opt/homebrew/bin/axl-node
# Start: bash scripts/setup_axl.sh
AXL_NODE_URL_QUANT=http://127.0.0.1:9011
AXL_NODE_URL_PATRIARCH=http://127.0.0.1:9012
AXL_NODE_URL_EXEC=http://127.0.0.1:9013
AXL_NODE_URL_KEEPERHUB=http://127.0.0.1:9014
AXL_NODE_URL_WATCHDOG=http://127.0.0.1:9015

# Per-process envelope signing keys (optional — daemons warn but continue if unset)
AXL_NODE_KEY_QUANT=0x...
AXL_NODE_KEY_PATRIARCH=0x...
AXL_NODE_KEY_EXEC=0x...
AXL_NODE_KEY_KEEPERHUB=0x...
AXL_NODE_KEY_WATCHDOG=0x...

# Demo mode: set to 1 to enforce live AXL (daemons refuse to start without AXL_NODE_URL_*)
DEMO_MODE=1

# Consensus
CONSENSUS_THRESHOLD=2
